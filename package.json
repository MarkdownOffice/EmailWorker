{
  "name": "markdownoffice-mailer",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker — daily scheduled email via Brevo API",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "logs": "wrangler tail --format pretty",
    "db:migrate": "wrangler d1 execute markdownoffice-mailer-db --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute markdownoffice-mailer-db --file=schema.sql --remote",
    "db:query": "wrangler d1 execute markdownoffice-mailer-db --remote --command",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260531.1",
    "typescript": "^5.9.3",
    "wrangler": "^3.106.0"
  }
}
